#!/bin/bash

terminal() {
  xdg-terminal-exec --app-id=omarchy.Omarchy -e "$@"
}

# Build the complete flat menu
build_menu() {
  cat <<EOF
ÔĄú  Keybindings
ůįĻĎ  Screenshot: Snap with Editing
ÔÉ™  Screenshot: Straight to Clipboard
ÔĄą  Screenrecord: Desktop audio
ÔĄį  Screenrecord: Desktop + microphone audio
ÔÄĹ  Screenrecord: Desktop + microphone audio + webcam
ÔáĽ  Pick Color
Óėł  Audio Setup
Ôáę  Wifi Setup
ůįāĮ  Bluetooth Setup
ůįĆĺ  Lock ¬∑ System
ůį§Ą  Suspend ¬∑ System
ůį§Ā  Hibernate ¬∑ System
ůįúČ  Restart ¬∑ System
ůįź•  Shutdown ¬∑ System
EOF
}

show_main_menu() {
  local selection
  selection=$(build_menu | launch-walker --dmenu -p "Go‚Ä¶" 2>/dev/null)

  case "$selection" in
    *Keybindings*) system-menu-keybindings ;;
    *"Snap with Editing"*) omarchy-cmd-screenshot smart ;;
    *"Straight to Clipboard"*) omarchy-cmd-screenshot smart clipboard ;;
    *"Desktop + microphone audio + webcam"*)
      if ! omarchy-cmd-screenrecord --stop-recording; then
        omarchy-cmd-screenrecord --with-desktop-audio --with-microphone-audio --with-webcam
      fi
      ;;
    *"Desktop + microphone audio"*)
      if ! omarchy-cmd-screenrecord --stop-recording; then
        omarchy-cmd-screenrecord --with-desktop-audio --with-microphone-audio
      fi
      ;;
    *"Desktop audio"*)
      if ! omarchy-cmd-screenrecord --stop-recording; then
        omarchy-cmd-screenrecord --with-desktop-audio
      fi
      ;;
    *"Color"*) pkill hyprpicker || hyprpicker -a ;;
    *"Audio"*) xdg-terminal-exec --app-id=omarchy.Wiremix -e wiremix ;;
    *"Wifi"*)
      rfkill unblock wifi
      launch-wifi
      ;;
    *"Bluetooth"*)
      rfkill unblock bluetooth
      blueberry
      ;;
    *"Lock"*) lock-screen ;;
    *"Suspend"*) systemctl suspend ;;
    *"Hibernate"*) systemctl hibernate ;;
    *"Restart"*) systemctl reboot --no-wall ;;
    *"Shutdown"*) systemctl poweroff --no-wall ;;
  esac
}

show_main_menu
