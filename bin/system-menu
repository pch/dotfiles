#!/bin/bash

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ "$BACK_TO_EXIT" == "true" ]]; then
    exit 0
  elif [[ -n "$parent_menu" ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n "$preselect" ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n "$index" ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | launch-walker --dmenu --width 295 --minheight 1 --maxheight 600 -p "$prompt‚Ä¶" "${args[@]}" 2>/dev/null
}

terminal() {
  $TERMINAL --class=omarchy.Omarchy -e "$@"
}

show_learn_menu() {
  case $(menu "Learn" "ÔĄú  Keybindings") in
  *Keybindings*) system-menu-keybindings ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "ÔÄį  Capture\nÔĒé  Share") in
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "ÔÄį  Screenshot\nÔÄĹ  Screenrecord\nůįÉČ  Color") in
  *Screenshot*) show_screenshot_menu ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) show_trigger_menu ;;
  esac
}

show_screenshot_menu() {
  case $(menu "Screenshot" "ÔÄį  Snap with Editing\nÔÄį  Straight to Clipboard") in
  *Editing*) omarchy-cmd-screenshot smart ;;
  *Clipboard*) omarchy-cmd-screenshot smart clipboard ;;
  *) show_capture_menu ;;
  esac
}

show_screenrecord_menu() {
  case $(menu "Screenrecord" "ÔÄĹ  Region\nÔÄĹ  Region + Audio\nÔÄĹ  Display\nÔÄĹ  Display + Audio\nÔÄĹ  Display + Webcam") in
  *"Region + Audio"*) omarchy-cmd-screenrecord region --with-audio ;;
  *Region*) omarchy-cmd-screenrecord ;;
  *"Display + Audio"*) omarchy-cmd-screenrecord output --with-audio ;;
  *"Display + Webcam"*) omarchy-cmd-screenrecord output --with-audio --with-webcam ;;
  *Display*) omarchy-cmd-screenrecord output ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "ÔĀŅ  Clipboard\nÓ©Ľ  File \nÔĄĒ  Folder") in
  *Clipboard*) terminal bash -c "omarchy-cmd-share clipboard" ;;
  *File*) terminal bash -c "omarchy-cmd-share file" ;;
  *Folder*) terminal bash -c "omarchy-cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_style_menu() {
  case $(menu "Style" "ůįłĆ  Theme\nÔÄĺ  Background") in
  *Theme*) show_theme_menu ;;
  *Background*) system-theme bg-next ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  theme=$(menu "Theme" "$(system-theme list)" "" "$(system-theme)")
  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    system-theme set "$theme"
  fi
}

show_setup_menu() {
  local options="Óėł  Audio\nÔáę  Wifi\nůįāĮ  Bluetooth\nůĪźč  Power Profile"

  case $(menu "Setup" "$options") in
  *Audio*) $TERMINAL --class=omarchy.Wiremix -e wiremix ;;
  *Wifi*)
    rfkill unblock wifi
    launch-wifi
    ;;
  *Bluetooth*)
    rfkill unblock bluetooth
    blueberry
    ;;
  *Power*) show_setup_power_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ "$profile" == "CNCLD" || -z "$profile" ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_install_menu() {
  case $(menu "Install" "ůį£á  Package\nůį£á  AUR") in
  *Package*) terminal system-pkg install ;;
  *AUR*) terminal system-pkg aur-install ;;
  *) show_main_menu ;;
  esac
}

show_system_menu() {
  case $(menu "System" "ÔÄ£  Lock\nůį§Ą  Suspend\nůį§Ā  Hibernate\nůįúČ  Restart\nůįź•  Shutdown") in
  *Lock*) lock-screen ;;
  *Suspend*) systemctl suspend ;;
  *Hibernate*) systemctl hibernate ;;
  *Restart*) systemctl reboot --no-wall ;;
  *Shutdown*) systemctl poweroff --no-wall ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "ůįÄĽ  Apps\nůįßĎ  Learn\nůĪďě  Trigger\nÓĮŹ  Style\nÓėē  Setup\nůįČČ  Install\nÔÄĎ  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) walker -p "Launch‚Ä¶" ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *share*) show_share_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenshot*) show_screenshot_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *system*) show_system_menu ;;
  esac
}

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
